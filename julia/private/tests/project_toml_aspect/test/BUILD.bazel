# Test to validate that dependency paths in Project.toml files exist
julia_test(
    name = "project_toml_path_validation_test",
    srcs = ["project_toml_path_validation_test.jl"],
    data = [
        ":golden_calc_utils_project_toml",
        ":golden_math_utils_project_toml",
        ":golden_multi_deps_test_project_toml",
        ":golden_string_utils_project_toml",
    ],
    env = {
        "PROJECT_TOML": "$(rlocationpath :golden_multi_deps_test_project_toml)",
    },
    deps = ["//julia/runfiles"],
)
