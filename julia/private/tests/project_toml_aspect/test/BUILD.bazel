# Version-specific golden file aliases.
# When --//julia/settings:version=1.10.10 is set, use the v1_10_10 golden files;
# otherwise use the default (1.12.5) golden files.
_GOLDEN_FILES = {
    "golden_calc_utils_manifest_toml": {
        "default": "golden_calc_utils.Manifest.toml",
        "v1_10_10": "golden_calc_utils.v1_10_10.Manifest.toml",
    },
    "golden_calc_utils_project_toml": {
        "default": "golden_calc_utils.Project.toml",
        "v1_10_10": "golden_calc_utils.v1_10_10.Project.toml",
    },
    "golden_math_utils_manifest_toml": {
        "default": "golden_math_utils.Manifest.toml",
        "v1_10_10": "golden_math_utils.v1_10_10.Manifest.toml",
    },
    "golden_math_utils_project_toml": {
        "default": "golden_math_utils.Project.toml",
        "v1_10_10": "golden_math_utils.v1_10_10.Project.toml",
    },
    "golden_multi_deps_test_manifest_toml": {
        "default": "golden_multi_deps_test.Manifest.toml",
        "v1_10_10": "golden_multi_deps_test.v1_10_10.Manifest.toml",
    },
    "golden_multi_deps_test_project_toml": {
        "default": "golden_multi_deps_test.Project.toml",
        "v1_10_10": "golden_multi_deps_test.v1_10_10.Project.toml",
    },
    "golden_string_utils_manifest_toml": {
        "default": "golden_string_utils.Manifest.toml",
        "v1_10_10": "golden_string_utils.v1_10_10.Manifest.toml",
    },
    "golden_string_utils_project_toml": {
        "default": "golden_string_utils.Project.toml",
        "v1_10_10": "golden_string_utils.v1_10_10.Project.toml",
    },
}

[
    alias(
        name = name,
        actual = select({
            "//julia/settings:version_1.10.10": files["v1_10_10"],
            "//conditions:default": files["default"],
        }),
    )
    for name, files in _GOLDEN_FILES.items()
]

# Diff tests to verify the generated Project.toml files match expected content
diff_test(
    name = "multi_deps_test_project_toml_diff",
    file1 = ":golden_multi_deps_test_project_toml",
    file2 = ":multi_deps_test_project_toml",
)

diff_test(
    name = "math_utils_project_toml_diff",
    file1 = ":golden_math_utils_project_toml",
